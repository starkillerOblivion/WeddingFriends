<Window x:Class="WeddingFriends.Windows.ActorStatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingFriends.Windows"
        mc:Ignorable="d"
        Title="ActorStatisticsWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock x:Name="tbActorName" FontWeight="Bold" FontSize="20"/>
        <TextBlock Text="Количество заказов:" Margin="0,10,0,0"/>
        <TextBlock x:Name="tbOrdersCount"/>
        <TextBlock Text="Средний рейтинг в заказах (оценки качества):" Margin="0,10,0,0"/>
        <TextBlock x:Name="tbAvgRating"/>
        <TextBlock Text="История заказов:" Margin="0,10,0,0"/>
        <ListBox x:Name="lvOrders" Height="200">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Order.OrderID, StringFormat='Заказ №{0}'}"/>
                        <TextBlock Text=" – "/>
                        <TextBlock Text="{Binding Order.OrderDate, StringFormat='dd.MM.yyyy'}"/>
                        <TextBlock Text=" – часов: "/>
                        <TextBlock Text="{Binding HoursCount}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="Закрыть" Click="BtnClose_Click" Margin="0,15,0,0" Background="#FF69B4"/>
    </StackPanel>
</Window>
