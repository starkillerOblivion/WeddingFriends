<Window x:Class="WeddingFriends.Windows.BonusFineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingFriends.Windows"
        mc:Ignorable="d"
        Title="BonusFineWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Актёр:"/>
        <ComboBox x:Name="cmbActor" DisplayMemberPath="FullName" SelectedValuePath="ActorID"/>
        <TextBlock Text="Тип:" Margin="0,10,0,0"/>
        <ComboBox x:Name="cmbType" SelectedIndex="0">
            <ComboBoxItem Content="Премия"/>
            <ComboBoxItem Content="Штраф"/>
        </ComboBox>
        <TextBlock Text="Сумма:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbAmount"/>
        <TextBlock Text="Причина:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbReason" TextWrapping="Wrap" Height="80"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,20,0,0" Background="#FF69B4"/>
        <Button Content="Отмена" Click="BtnCancel_Click" Margin="0,5,0,0"/>
    </StackPanel>
</Window>
