<Window x:Class="WeddingFriends.Windows.QualityCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingFriends.Windows"
        mc:Ignorable="d"
        Title="QualityCheckWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Заказ №:" FontWeight="Bold"/>
        <TextBlock x:Name="tbOrderId"/>
        <TextBlock Text="Оценка качества (1-5):" Margin="0,10,0,0"/>
        <ComboBox x:Name="cmbRating" SelectedIndex="0">
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
        </ComboBox>
        <TextBlock Text="Комментарий:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbComment" TextWrapping="Wrap" Height="100"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,20,0,0" Background="#FF69B4"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
