<Window x:Class="WeddingFriends.Windows.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingFriends.Windows"
        mc:Ignorable="d"
        Title="EditUserWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Логин:"/>
        <TextBox x:Name="tbLogin"/>
        <TextBlock Text="Пароль (оставьте пустым, если не менять):" Margin="0,10,0,0"/>
        <PasswordBox x:Name="pbPassword"/>
        <TextBlock Text="Полное имя:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbFullName"/>
        <TextBlock Text="Телефон:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbPhone"/>
        <TextBlock Text="Email:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbEmail"/>
        <TextBlock Text="Роль:" Margin="0,10,0,0"/>
        <ComboBox x:Name="cmbRole" DisplayMemberPath="RoleName" SelectedValuePath="RoleID"/>
        <CheckBox x:Name="chkActive" Content="Активен" Margin="0,10,0,0"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,20,0,0" Background="#FF69B4"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
