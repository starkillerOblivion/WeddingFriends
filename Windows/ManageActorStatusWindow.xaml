<Window x:Class="WeddingFriends.Windows.ManageActorStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingFriends.Windows"
        mc:Ignorable="d"
        Title="ManageActorStatusWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Актёр:" FontWeight="Bold"/>
        <TextBlock x:Name="tbActorName" Margin="0,5,0,15"/>
        <TextBlock Text="Новый рейтинг (0-5):"/>
        <TextBox x:Name="tbRating"/>
        <TextBlock Text="Умеет пить?"/>
        <CheckBox x:Name="chkDrinkable"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,15,0,0" Background="#FF69B4"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
