<Window x:Class="WeddingFriends.Windows.EditScriptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeddingFriends.Windows"
        mc:Ignorable="d"
        Title="EditScriptWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Название сценария:"/>
        <TextBox x:Name="tbScriptName"/>
        <TextBlock Text="Описание:" Margin="0,10,0,0"/>
        <TextBox x:Name="tbDescription" TextWrapping="Wrap" Height="80"/>
        <TextBlock Text="Требуемые роли:" Margin="0,10,0,0"/>
        <ListBox x:Name="lbRequiredRoles" SelectionMode="Multiple" DisplayMemberPath="RoleName" Height="120"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,15,0,0" Background="#FF69B4"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
