<Page x:Class="WeddingFriends.Pages.CastingDirectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WeddingFriends.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CastingDirectorPage">

    <TabControl Margin="10">
        <TabItem Header="Заказы">
            <StackPanel>
                <ComboBox x:Name="cmbOrderStatus" SelectionChanged="cmbOrderStatus_SelectionChanged" Margin="5"/>
                <ListBox x:Name="lvOrders" Height="300">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding OrderID}" Width="50"/>
                                <TextBlock Text="{Binding Customers.User.FullName}" Width="150"/>
                                <TextBlock Text="{Binding Status}" Width="100"/>
                                <Button Content="Изменить статус" Tag="{Binding OrderID}" Click="ChangeOrderStatus_Click" Margin="5,0"/>
                                <Button Content="Контроль качества" Tag="{Binding OrderID}" Click="QualityCheck_Click" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Назначение актёров">
            <StackPanel>
                <ComboBox x:Name="cmbOrderForAssignment" DisplayMemberPath="OrderID" SelectionChanged="cmbOrderForAssignment_SelectionChanged" Margin="5"/>
                <ListBox x:Name="lvAvailableActors" Height="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FullName}" Width="150"/>
                                <Button Content="Назначить" Tag="{Binding ActorID}" Click="AssignActor_Click" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <ListBox x:Name="lvAssignedActors" Height="150" Margin="0,10,0,0"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Премии/штрафы">
            <StackPanel>
                <Button Content="Выдать премию/штраф" Click="AddBonusFine_Click" Margin="5"/>
                <ListBox x:Name="lvBonuses" Height="200"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Page>
