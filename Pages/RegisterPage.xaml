<Page x:Class="WeddingFriends.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WeddingFriends.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <StackPanel VerticalAlignment="Center" Width="400" Margin="20">
        <TextBlock Text="Логин" Margin="0,0,0,5"/>
        <TextBox x:Name="tbLogin" Margin="0,0,0,10"/>
        <TextBlock Text="Пароль" Margin="0,0,0,5"/>
        <PasswordBox x:Name="pbPassword" Margin="0,0,0,10"/>
        <TextBlock Text="Подтверждение пароля" Margin="0,0,0,5"/>
        <PasswordBox x:Name="pbPasswordConfirm" Margin="0,0,0,10"/>
        <TextBlock Text="Полное имя" Margin="0,0,0,5"/>
        <TextBox x:Name="tbFullName" Margin="0,0,0,10"/>
        <TextBlock Text="Телефон" Margin="0,0,0,5"/>
        <TextBox x:Name="tbPhone" Margin="0,0,0,10"/>
        <TextBlock Text="Email" Margin="0,0,0,5"/>
        <TextBox x:Name="tbEmail" Margin="0,0,0,20"/>
        <Button Content="Зарегистрироваться" Click="BtnRegister_Click" Background="#FF69B4"/>
        <TextBlock x:Name="tbError" Foreground="Red" Margin="0,10" TextAlignment="Center"/>
    </StackPanel>
</Page>
