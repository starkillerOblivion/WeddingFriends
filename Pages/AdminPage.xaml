<Page x:Class="WeddingFriends.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WeddingFriends.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <TabControl Margin="10">
        <TabItem Header="Пользователи">
            <StackPanel>
                <Button Content="Добавить пользователя" Name="btnAddUser" Click="btnAddUser_Click" Margin="5"/>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Visible">
                    <ListBox x:Name="lvUsers">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Login}" Width="120"/>
                                    <TextBlock Text="{Binding FullName}" Width="150"/>
                                    <Button Content="Редактировать" Tag="{Binding UserID}" Click="btnEditUser_Click"/>
                                    <Button Content="Удалить" Tag="{Binding UserID}" Click="btnDeleteUser_Click" Margin="5,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </StackPanel>
        </TabItem>
        <TabItem Header="Актёры">
            <StackPanel>
                <Button Content="Добавить актёра" Name="btnAddActor" Click="btnAddActor_Click" Margin="5"/>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Visible">
                    <ListBox x:Name="lvActors" DisplayMemberPath="FullName"/>
                </ScrollViewer>
            </StackPanel>
        </TabItem>
        <TabItem Header="Роли">
            <StackPanel>
                <Button Content="Добавить роль" Name="btnAddRole" Click="btnAddRole_Click" Margin="5"/>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Visible">
                    <ListBox x:Name="lvRoles" DisplayMemberPath="RoleName"/>
                </ScrollViewer>
            </StackPanel>
        </TabItem>
        <TabItem Header="Сценарии">
            <StackPanel>
                <Button Content="Добавить сценарий" Name="btnAddScript" Click="btnAddScript_Click" Margin="5"/>
                <ListBox x:Name="lvScripts" DisplayMemberPath="ScriptName"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Логи">
            <ListBox x:Name="lvLogs" Height="400">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActionTime, StringFormat='dd.MM.yyyy HH:mm'}"/>
                            <TextBlock Text=" – "/>
                            <TextBlock Text="{Binding AdminUser.Login}"/>
                            <TextBlock Text=": "/>
                            <TextBlock Text="{Binding ActionType}"/>
                            <TextBlock Text=" – "/>
                            <TextBlock Text="{Binding TableName}"/>
                            <TextBlock Text=" ID "/>
                            <TextBlock Text="{Binding RecordID}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>
    </TabControl>
</Page>
