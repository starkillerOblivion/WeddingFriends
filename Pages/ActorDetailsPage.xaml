<Page x:Class="WeddingFriends.Pages.ActorDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WeddingFriends.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ActorDetailsPage">

    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock x:Name="tbName" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
            <TextBlock x:Name="tbRoles" FontSize="18" Margin="0,10,0,0"/>
            <TextBlock x:Name="tbRating" FontSize="16" Margin="0,5,0,0"/>
            <TextBlock x:Name="tbDrinkable" FontSize="16" Margin="0,5,0,0"/>
            <TextBlock Text="История заказов" FontWeight="Bold" FontSize="20" Margin="0,20,0,5"/>
            <ListBox x:Name="lvOrders" Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="3">
                            <TextBlock Text="{Binding Order.OrderID, StringFormat='Заказ №{0}'}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Order.OrderDate, StringFormat='Дата: dd.MM.yyyy'}" />
                            <TextBlock Text="{Binding HoursCount, StringFormat='Часы: {0}'}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Text="Логи изменений" FontWeight="Bold" FontSize="20" Margin="0,20,0,5"/>
            <ListBox x:Name="lvLogs" Height="150">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActionTime, StringFormat='dd.MM.yyyy HH:mm'}"/>
                            <TextBlock Text=" – "/>
                            <TextBlock Text="{Binding ActionType}"/>
                            <TextBlock Text=": "/>
                            <TextBlock Text="{Binding Details}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</Page>
