<Application x:Class="WeddingFriends.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WeddingFriends"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="Pacifico">/Fonts/#Pacifico</FontFamily>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="Background" Value="#FFFAF0"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style TargetType="Page">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="Background" Value="#FFFAF0"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF69B4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#FFEBCD"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#FFEBCD"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#FFEBCD"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="FontFamily" Value="{StaticResource Pacifico}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="#FFFAF0"/>
        </Style>
    </Application.Resources>
</Application>
